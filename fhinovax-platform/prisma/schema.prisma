// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// NextAuth Required Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          String    @default("CLIENT") // ADMIN, STAFF, CLIENT
  profileSettings String? // JSON string for dynamic edit toggles
  
  accounts      Account[]
  sessions      Session[]
  jobs          Job[]
  payments      Payment[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Fhinovax Custom Models

model Service {
  id                String   @id @default(cuid())
  title             String
  slug              String   @unique
  description       String?
  basePrice         Float    @default(0.0)
  aiAutonomyLevel   String   @default("AI_AND_HUMAN") // AI_ONLY, AI_AND_HUMAN, HUMAN_ONLY
  turnaroundTime    String   @default("24 Hours")
  status            Boolean  @default(true)
  
  jobs              Job[]
}

model Job {
  id                String   @id @default(cuid())
  userId            String
  serviceId         String
  inputData         String?  // JSON
  outputData        String?  // Text / JSON
  status            String   @default("PENDING") // PENDING, PROCESSING, REVIEW, COMPLETED, CANCELLED
  priority          String   @default("STANDARD")
  complexityScore   Float?
  aiConfidenceScore Float?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user              User     @relation(fields: [userId], references: [id])
  service           Service  @relation(fields: [serviceId], references: [id])
  payments          Payment[]
  aiLogs            AiLog[]
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  jobId             String?
  amount            Float
  currency          String   @default("NGN")
  referenceToken    String   @unique
  paymentMethod     String   // paystack, flutterwave, bank_transfer
  status            String   @default("PENDING") // PENDING, COMPLETED, FAILED, VERIFICATION_REQUIRED
  proofOfPaymentPath String?
  
  verifiedAt        DateTime?
  verifiedByAdminId String?
  
  createdAt         DateTime @default(now())
  
  user              User     @relation(fields: [userId], references: [id])
  job               Job?     @relation(fields: [jobId], references: [id])
}

model AiLog {
  id                String   @id @default(cuid())
  jobId             String
  agentType         String
  action            String
  confidenceScore   Float?
  timestamp         DateTime @default(now())
  
  job               Job      @relation(fields: [jobId], references: [id])
}
